{
	"name": "@19h47/slider",
	"version": "2.0.0",
	"description": "Slider",
	"type": "module",
	"main": "dist/slider.umd.cjs",
	"module": "dist/slider.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/slider.js",
			"require": "./dist/slider.umd.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "vite",
		"build:types": "tsc -p tsconfig.build.json",
		"build": "vite build && pnpm run build:types",
		"deploy": "npm login && npm run build && npm publish"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/19h47/19h47-slider.git"
	},
	"keywords": [
		"input",
		"slider",
		"ES6"
	],
	"author": "Jérémy Levron <jeremylevron@19h47.fr> (https://19h47.fr)",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/19h47/19h47-slider/issues"
	},
	"homepage": "https://github.com/19h47/19h47-slider#readme",
	"devDependencies": {
		"typescript": "^5.9.2",
		"vite": "^6.3.4"
	}
}
